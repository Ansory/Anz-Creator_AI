# === ANZ-CREATOR Environment Variables ===

# Gemini API Keys (comma-separated). Bisa juga diisi via UI API Key Manager.
GEMINI_API_KEYS=

# Pexels API Key (https://www.pexels.com/api/)
PEXELS_API_KEY=

# Pixabay API Key (https://pixabay.com/api/docs/)
PIXABAY_API_KEY=

# Server port (default 8080)
SERVER_PORT=2712

# Output directory
OUTPUT_DIR=./outputs
