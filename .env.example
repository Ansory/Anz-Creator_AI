# === ANZ-CREATOR Environment Variables ===

# Gemini API Keys (comma-separated). Bisa juga diisi via UI API Key Manager.
# Dapatkan gratis di: https://aistudio.google.com/app/apikey
GEMINI_API_KEYS=

# Server port (default 2712)
SERVER_PORT=2712

# Output directory (relatif ke folder app, atau absolut)
OUTPUT_DIR=./outputs

# (Opsional) Path eksplisit ke binary FFmpeg / ffprobe kalau tidak ada di PATH
# FFMPEG_BIN=C:\ffmpeg\bin\ffmpeg.exe
# FFPROBE_BIN=C:\ffmpeg\bin\ffprobe.exe
